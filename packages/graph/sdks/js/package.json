    "fixtures:check": "tsx src/scripts/fixtures/check-fixtures.ts",
    "fixtures:update": "tsx src/scripts/fixtures/check-fixtures.ts --update"
  },
  "dependencies": {
    "@chris-test/fcp": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.8.3"
